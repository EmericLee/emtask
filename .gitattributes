# 统一行尾为 LF，避免 Windows 上 CRLF/LF 警告
* text=auto eol=lf

# 明确指定文本文件使用 LF
*.dart text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.gradle text eol=lf
*.kts text eol=lf
*.cmake text eol=lf
*.plist text eol=lf
*.entitlements text eol=lf
*.xcconfig text eol=lf
*.properties text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Windows 批处理脚本必须使用 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# 二进制文件（不做行尾转换）
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.pdf binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.jar binary
*.zip binary
*.gz binary
*.dll binary
*.so binary
*.dylib binary
*.exe binary
*.pdb binary
*.mdb binary
*.db binary
*.sqlite binary
*.sqlite3 binary
